<h2>Edit <%= @card.name %></h2>
<%= form_with url: request.path, :class => "pure-form pure-form-aligned" do |form| %>
  <fieldset>
    <div class="pure-control-group">
      <label for="name_field">Card Title</label>
      <%= form.text_field :name, required: true, autofocus: true, value: @card.name, :class => "pure-input-1-2", :id => "name_field" %>
    </div>
    <div class="pure-control-group">
      <label for="free_space_field">Free Space</label>
      <%= form.text_field :free_space, required: true, value: @card.free_space, :class => "pure-input-1-2", :id => "free_space_field" %>
    </div>
    <div class="pure-control-group">
      <%= form.submit "Edit card", :class => "pure-button pure-button-primary" %>
    </div>
  </fieldset>
<% end %>

<h2>Fields</h2>
<div class="pure-form">
  <input type="text" class="pure-input pure-input-3-4" id="fields-add-text" placeholder="New Field..."></input>
  <button class="pure-button pure-button-primary" id="fields-add-button" card_id="<%= @card.id %>">Add Field</button>
</div>

<div class="pure-g">
  <div class="pure-u-4-5">
    <p id="how-many"</p> 
  </div>
  <div class="pure-u-1-5">
    <a id="play-button" class="pure-button" style="display: none" href="/card/<%= @card.id %>">Play Card</a>
  </div>
</div>

<ol id="fields-container" card_id="<%= @card.id %>"></ol>
</script>
